<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Non-sandboxed (foundation decision): the app reads the Claude Keychain item,
	     writes ~/.claude/settings.json and ~/.config. App-sandbox is intentionally OFF. -->
	<key>com.apple.security.network.client</key>
	<true/>
</dict>
</plist>
